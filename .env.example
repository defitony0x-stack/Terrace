# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# The MomentMarket backend's public URL — Terrace calls its /api/fixtures
# endpoint for match data. Same data, no separate TxLINE session/wallet.
MOMENTMARKET_API_URL=https://momentsite-production.up.railway.app

# Must match MOMENT_WEBHOOK_SECRET on the MomentMarket backend, if set there.
MOMENT_WEBHOOK_SECRET=

# Powers Terry, the AI commentator voice — used for EVERY live moment
# (goal, card, corner, shot, VAR) as well as replies when tagged. Get a
# key from Google AI Studio (aistudio.google.com). Leave blank and
# Terrace still posts live moments fine, just as plain template lines
# ("⚽ GOAL 67' — Vietnam") instead of Terry's commentary, and it won't
# respond to tagged questions.
GEMINI_API_KEY=
# Optional override — defaults to gemini-2.5-flash (the low-cost, fast
# tier, a good fit for short per-event commentary lines).
GEMINI_MODEL=gemini-2.5-flash

# Minutes of no confirmed events before Terry chimes in with ambient
# "keeping the chat alive" commentary during quiet stretches. Checked
# every 2 minutes; this is the actual idle threshold. Lower = chattier.
TERRACE_AMBIENT_IDLE_MINUTES=5

# Where Terrace's own SQLite file lives. On Railway, set this to a path
# under a mounted Volume (e.g. /data/terrace.db) to survive redeploys.
DB_PATH=./terrace.db

PORT=8081
